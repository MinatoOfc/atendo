# ============================================================
#  Atendo — variáveis de ambiente
#  Copie este arquivo para ".env" e preencha os valores.
#  No Railway, cadastre estas mesmas variáveis em Settings > Variables.
# ============================================================

# Porta (o Railway define automaticamente; local usa 3000)
PORT=3000

# Segredo para assinar os tokens de login (JWT).
# Gere um valor longo e aleatório. Ex.: no terminal rode:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=troque-por-um-valor-longo-e-aleatorio

# Banco de dados PostgreSQL.
# No Railway: adicione um plugin PostgreSQL e ele cria DATABASE_URL sozinho.
# Deixe em branco para rodar localmente com armazenamento em memória (só teste).
DATABASE_URL=

# --- IA (opcional nesta etapa) ---
# Preencha SÓ UMA. Se as duas estiverem vazias, o app usa uma resposta simulada.
# Claude (Anthropic): https://console.anthropic.com/  -> API Keys
ANTHROPIC_API_KEY=
# OpenAI (GPT): https://platform.openai.com/api-keys
OPENAI_API_KEY=
